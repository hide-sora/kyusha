---
import Layout from '../layouts/Layout.astro';
const SQUARE_APP_ID = import.meta.env.PUBLIC_SQUARE_APP_ID || '';
const SQUARE_LOCATION_ID = import.meta.env.PUBLIC_SQUARE_LOCATION_ID || '';
---
<Layout title="コントロールパネル">
  <main class="min-h-screen p-4 max-w-lg mx-auto space-y-4 pb-8">
    <div class="flex items-center gap-3 pt-6">
      <img src="/mito-logo.png" alt="水戸道楽TV" class="h-10 w-auto" />
      <h1 class="font-display font-800 text-xl text-on-surface">当日コントロールパネル</h1>
    </div>

    {/* マップ切替 */}
    <section class="card-elevated p-5 space-y-4">
      <h2 class="font-display font-700 text-base text-on-surface flex items-center gap-2">
        <span class="i-ph-map-trifold-duotone text-lg" />
        マップ
      </h2>
      <div class="flex gap-2">
        <button id="map-default" class="flex-1 py-3 rounded-xl font-display font-700 text-sm bg-surface-container-highest text-on-surface-variant active:scale-95 transition-transform">
          通常マップ
        </button>
        <button id="map-event" class="flex-1 py-3 rounded-xl font-display font-700 text-sm bg-primary text-on-primary active:scale-95 transition-transform">
          イベントマップ
        </button>
      </div>
      <p id="map-status" class="text-xs text-on-surface-variant text-center">---</p>
    </section>

    {/* NavBar タブ表示切替 */}
    <section class="card-elevated p-5 space-y-4">
      <h2 class="font-display font-700 text-base text-on-surface flex items-center gap-2">
        <span class="i-ph-list-bold text-lg" />
        NavBar 表示
      </h2>
      <p class="text-xs text-on-surface-variant">下部タブバーの「投票」「オークション」を表示するか切り替えます</p>

      <div>
        <p class="text-[10px] font-700 tracking-widest uppercase text-on-surface-variant mb-2">投票タブ</p>
        <div class="flex gap-2">
          <button id="voting-on" class="flex-1 py-2.5 rounded-xl font-display font-700 text-xs bg-surface-container-highest text-on-surface-variant active:scale-95 transition-transform">
            表示
          </button>
          <button id="voting-off" class="flex-1 py-2.5 rounded-xl font-display font-700 text-xs bg-surface-container-highest text-on-surface-variant active:scale-95 transition-transform">
            非表示
          </button>
        </div>
      </div>

      <div>
        <p class="text-[10px] font-700 tracking-widest uppercase text-on-surface-variant mb-2">オークションタブ</p>
        <div class="flex gap-2">
          <button id="auction-on" class="flex-1 py-2.5 rounded-xl font-display font-700 text-xs bg-surface-container-highest text-on-surface-variant active:scale-95 transition-transform">
            表示
          </button>
          <button id="auction-off" class="flex-1 py-2.5 rounded-xl font-display font-700 text-xs bg-surface-container-highest text-on-surface-variant active:scale-95 transition-transform">
            非表示
          </button>
        </div>
      </div>
    </section>

    {/* 投票ランキング表示切替 */}
    <section class="card-elevated p-5 space-y-4">
      <h2 class="font-display font-700 text-base text-on-surface flex items-center gap-2">
        <span class="i-ph-trophy-duotone text-lg" />
        投票ランキング
      </h2>
      <p class="text-xs text-on-surface-variant">/vote ページ下部のランキング表示を切り替えます</p>
      <div class="flex gap-2">
        <button id="ranking-on" class="flex-1 py-3 rounded-xl font-display font-700 text-sm bg-surface-container-highest text-on-surface-variant active:scale-95 transition-transform">
          表示する
        </button>
        <button id="ranking-off" class="flex-1 py-3 rounded-xl font-display font-700 text-sm bg-surface-container-highest text-on-surface-variant active:scale-95 transition-transform">
          非表示
        </button>
      </div>
      <p id="ranking-status" class="text-xs text-on-surface-variant text-center">---</p>
    </section>

    {/* 1円決済テスト */}
    <section class="card-elevated p-5 space-y-4">
      <h2 class="font-display font-700 text-base text-on-surface flex items-center gap-2">
        <span class="i-ph-credit-card-duotone text-lg" />
        1円決済テスト
      </h2>
      <p class="text-xs text-on-surface-variant">Square Web Payments SDKで1円決済をテストします</p>

      <div id="test-pay-form" class="space-y-3">
        <div id="test-card-container" class="min-h-[100px] bg-surface-container-low rounded-xl p-3"></div>
        <button id="test-pay-btn" class="w-full py-3 rounded-xl bg-primary text-on-primary font-display font-700 text-sm active:scale-95 transition-transform disabled:opacity-50">
          1円を決済する
        </button>
        <p id="test-pay-error" class="text-xs text-error hidden"></p>
      </div>

      <div id="test-pay-success" class="hidden text-center py-6">
        <div class="w-16 h-16 rounded-full bg-secondary-container flex-center mx-auto mb-4">
          <span class="i-ph-check-circle-duotone text-4xl text-secondary" />
        </div>
        <h3 class="font-display font-800 text-xl text-on-surface mb-1">決済成功</h3>
        <p class="text-xs text-on-surface-variant mb-4">ご購入ありがとうございます</p>

        <div class="bg-surface-container-low rounded-xl p-4 mb-4">
          <div class="flex items-center justify-center gap-6">
            <div>
              <p class="text-[10px] text-on-surface-variant">大人</p>
              <p class="font-display font-800 text-3xl text-on-surface">1<span class="text-xs font-600 ml-0.5">名</span></p>
            </div>
            <div class="w-px h-8 bg-outline-variant/30" />
            <div>
              <p class="text-[10px] text-on-surface-variant">子供</p>
              <p class="font-display font-800 text-3xl text-on-surface">0<span class="text-xs font-600 ml-0.5">名</span></p>
            </div>
          </div>
        </div>

        <div class="bg-amber-100 text-amber-900 rounded-xl p-3 mb-3 flex items-center gap-2">
          <span class="i-ph-hand-waving-duotone text-lg shrink-0" />
          <p class="text-xs font-700 text-left">この画面をスタッフにお見せください</p>
        </div>

        <div class="grid grid-cols-2 gap-2 mb-4">
          <div class="bg-surface-container-low rounded-xl p-3 text-center">
            <span class="i-ph-camera-duotone text-xl text-on-surface-variant mb-1 block mx-auto" />
            <p class="text-[10px] text-on-surface-variant leading-tight">スクショで<br/>保存しておく</p>
          </div>
          <div class="bg-surface-container-low rounded-xl p-3 text-center">
            <span class="i-ph-envelope-simple-duotone text-xl text-on-surface-variant mb-1 block mx-auto" />
            <p class="text-[10px] text-on-surface-variant leading-tight">メールでも<br/>送信済み</p>
          </div>
        </div>

        <p id="test-pay-ticket" class="text-[10px] text-on-surface-variant/60 font-mono"></p>
        <button id="test-pay-again" class="mt-4 text-xs text-on-surface-variant underline">もう一度テストする</button>
      </div>
    </section>

    {/* ログ */}
    <div id="log" class="text-[10px] text-on-surface-variant font-mono bg-surface-container-low rounded-xl p-3 min-h-[60px] max-h-[200px] overflow-y-auto whitespace-pre-wrap"></div>
  </main>
</Layout>

<script define:vars={{ SQUARE_APP_ID, SQUARE_LOCATION_ID }}>
  const log = document.getElementById('log');
  function addLog(msg) {
    log.textContent = `[${new Date().toLocaleTimeString()}] ${msg}\n` + log.textContent;
  }

  async function api(action, extra = {}) {
    addLog(`${action} ...`);
    try {
      const res = await fetch('/api/admin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, ...extra }),
      });
      const data = await res.json();
      addLog(`${action} → OK`);
      return data;
    } catch (e) {
      addLog(`${action} → ERROR: ${e.message}`);
      return { error: e.message };
    }
  }

  async function refreshStatus() {
    const { config } = await api('get_config');
    if (!config) return;

    // マップ
    const mapEvent = config.map_event;
    document.getElementById('map-status').textContent = mapEvent ? '現在: イベントマップ' : '現在: 通常マップ';
    document.getElementById('map-default').className = `flex-1 py-3 rounded-xl font-display font-700 text-sm active:scale-95 transition-transform ${
      !mapEvent ? 'bg-on-surface text-surface' : 'bg-surface-container-highest text-on-surface-variant'
    }`;
    document.getElementById('map-event').className = `flex-1 py-3 rounded-xl font-display font-700 text-sm active:scale-95 transition-transform ${
      mapEvent ? 'bg-primary text-on-primary' : 'bg-surface-container-highest text-on-surface-variant'
    }`;

    // NavBar 投票/オークション表示
    const votingOn = !!config.voting_open;
    const auctionOn = !!config.auction_open;
    document.getElementById('voting-on').className = `flex-1 py-2.5 rounded-xl font-display font-700 text-xs active:scale-95 transition-transform ${
      votingOn ? 'bg-secondary text-on-secondary' : 'bg-surface-container-highest text-on-surface-variant'
    }`;
    document.getElementById('voting-off').className = `flex-1 py-2.5 rounded-xl font-display font-700 text-xs active:scale-95 transition-transform ${
      !votingOn ? 'bg-on-surface text-surface' : 'bg-surface-container-highest text-on-surface-variant'
    }`;
    document.getElementById('auction-on').className = `flex-1 py-2.5 rounded-xl font-display font-700 text-xs active:scale-95 transition-transform ${
      auctionOn ? 'bg-primary text-on-primary' : 'bg-surface-container-highest text-on-surface-variant'
    }`;
    document.getElementById('auction-off').className = `flex-1 py-2.5 rounded-xl font-display font-700 text-xs active:scale-95 transition-transform ${
      !auctionOn ? 'bg-on-surface text-surface' : 'bg-surface-container-highest text-on-surface-variant'
    }`;

    // ランキング
    const rankingOn = !!config.ranking_visible;
    document.getElementById('ranking-status').textContent = rankingOn ? '現在: 表示中' : '現在: 非表示';
    document.getElementById('ranking-on').className = `flex-1 py-3 rounded-xl font-display font-700 text-sm active:scale-95 transition-transform ${
      rankingOn ? 'bg-secondary text-on-secondary' : 'bg-surface-container-highest text-on-surface-variant'
    }`;
    document.getElementById('ranking-off').className = `flex-1 py-3 rounded-xl font-display font-700 text-sm active:scale-95 transition-transform ${
      !rankingOn ? 'bg-on-surface text-surface' : 'bg-surface-container-highest text-on-surface-variant'
    }`;
  }

  document.getElementById('map-default').addEventListener('click', async () => {
    await api('set_config', { map_event: false });
    refreshStatus();
  });
  document.getElementById('map-event').addEventListener('click', async () => {
    await api('set_config', { map_event: true });
    refreshStatus();
  });
  document.getElementById('voting-on').addEventListener('click', async () => {
    await api('set_config', { voting_open: true });
    refreshStatus();
  });
  document.getElementById('voting-off').addEventListener('click', async () => {
    await api('set_config', { voting_open: false });
    refreshStatus();
  });
  document.getElementById('auction-on').addEventListener('click', async () => {
    await api('set_config', { auction_open: true });
    refreshStatus();
  });
  document.getElementById('auction-off').addEventListener('click', async () => {
    await api('set_config', { auction_open: false });
    refreshStatus();
  });
  document.getElementById('ranking-on').addEventListener('click', async () => {
    await api('set_config', { ranking_visible: true });
    refreshStatus();
  });
  document.getElementById('ranking-off').addEventListener('click', async () => {
    await api('set_config', { ranking_visible: false });
    refreshStatus();
  });

  refreshStatus();

  // Square Web Payments SDK
  async function initSquare() {
    if (!SQUARE_APP_ID || !SQUARE_LOCATION_ID) {
      document.getElementById('test-pay-error').textContent = 'Square 設定が見つかりません';
      document.getElementById('test-pay-error').classList.remove('hidden');
      return;
    }

    await new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = 'https://web.squarecdn.com/v1/square.js';
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });

    const payments = window.Square.payments(SQUARE_APP_ID, SQUARE_LOCATION_ID);
    const card = await payments.card();
    await card.attach('#test-card-container');

    document.getElementById('test-pay-btn').addEventListener('click', async () => {
      const btn = document.getElementById('test-pay-btn');
      const err = document.getElementById('test-pay-error');
      err.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = '決済中...';

      try {
        const result = await card.tokenize();
        if (result.status !== 'OK') {
          throw new Error(result.errors?.[0]?.message || 'トークン化失敗');
        }

        const res = await fetch('/api/payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            sourceId: result.token,
            ticketType: 'test_1yen',
            quantity: 1,
            childQuantity: 0,
            name: 'テスト',
            email: 'test@example.com',
            amount: 1,
          }),
        });
        const data = await res.json();
        if (!res.ok || data.error) throw new Error(data.error || '決済失敗');

        addLog(`決済成功: ${data.ticketCode || data.orderId || 'OK'}`);
        document.getElementById('test-pay-form').classList.add('hidden');
        document.getElementById('test-pay-success').classList.remove('hidden');
        if (data.ticketCode) {
          document.getElementById('test-pay-ticket').textContent = `チケットNo: ${data.ticketCode}`;
        }
      } catch (e) {
        err.textContent = e.message;
        err.classList.remove('hidden');
        addLog(`決済失敗: ${e.message}`);
      } finally {
        btn.disabled = false;
        btn.textContent = '1円を決済する';
      }
    });
  }

  document.getElementById('test-pay-again').addEventListener('click', () => {
    document.getElementById('test-pay-success').classList.add('hidden');
    document.getElementById('test-pay-form').classList.remove('hidden');
  });

  initSquare().catch(e => {
    addLog(`Square init失敗: ${e.message}`);
    document.getElementById('test-pay-error').textContent = e.message;
    document.getElementById('test-pay-error').classList.remove('hidden');
  });
</script>
