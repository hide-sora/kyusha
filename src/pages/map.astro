---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/common/Nav.astro';
import { zones } from '../data/zones';
---
<Layout title="会場マップ">
  <main class="min-h-screen pb-28">
    <header class="px-6 pt-12 pb-8">
      <p class="label-upper text-primary mb-2">Location Detail</p>
      <h1 class="font-display font-800 text-4xl tracking-tight text-on-surface mb-2">
        会場マップ
      </h1>
      <div class="flex items-center gap-2 mt-2">
        <span class="i-ph-map-pin-duotone text-secondary text-sm" />
        <span class="text-xs font-500 text-on-surface-variant tracking-wide">栃木県 — モビリティリゾートもてぎ 南コース</span>
      </div>
    </header>

    {/* SVGマップ */}
    <section class="px-4 mb-8">
      <div class="relative bg-surface-container-low rounded-xl overflow-hidden aspect-[4/3] flex-center">
        <div class="text-center">
          <span class="i-ph-map-trifold-duotone text-6xl text-on-surface-variant/15 block mb-3" />
          <p class="text-sm text-on-surface-variant">会場マップ準備中</p>
          <p class="text-xs text-on-surface-variant/60 mt-1">デザイン完成後に差し替え</p>
        </div>
      </div>
    </section>

    {/* エリア一覧 */}
    <section class="px-4">
      <h2 class="font-display font-700 text-lg text-on-surface mb-4 px-2">展示エリア</h2>
      <div class="space-y-3 max-w-lg mx-auto">
        {zones.map(zone => (
          <div class="flex items-center gap-4 p-4 bg-surface-container-lowest rounded-xl">
            <div
              class="w-10 h-10 rounded-full flex-center font-display font-700 text-lg text-white shrink-0"
              style={`background-color: ${zone.color}`}
            >
              {zone.id}
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-display font-700 text-sm text-on-surface">{zone.name}</h3>
              <p class="text-xs text-on-surface-variant truncate">{zone.description}</p>
            </div>
            <div class="text-right shrink-0">
              <span class="font-display font-700 text-lg text-on-surface">{zone.carCount}</span>
              <span class="text-[10px] text-on-surface-variant block tracking-widest uppercase">台</span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Nav />
</Layout>
