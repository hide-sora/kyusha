---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/common/Nav.astro';

const PB_URL = import.meta.env.PUBLIC_PB_URL || 'http://133.18.160.234:8093';
let mapEvent = false;
try {
  const res = await fetch(`${PB_URL}/api/collections/event_config/records?perPage=1`);
  const data = await res.json();
  mapEvent = data.items?.[0]?.map_event ?? false;
} catch {}

const mapSrc = mapEvent ? '/map/venue-map-event.svg' : '/map/venue-map.svg';
---
<Layout title="会場マップ">
  <main class="min-h-screen pb-nav-safe">
    <header class="px-6 pt-12 pb-8">
      <p class="label-upper text-primary mb-2">まずはここをチェック！</p>
      <h1 class="font-display font-800 text-4xl tracking-tight text-on-surface mb-2">
        会場マップ
      </h1>
      <p class="text-sm text-on-surface-variant leading-relaxed mb-2">
        広い会場なので、見たいエリアを先に確認しておくとスムーズです
      </p>
      <div class="flex items-center gap-2 mt-1">
        <span class="i-ph-map-pin-duotone text-secondary text-sm" />
        <a href="https://maps.app.goo.gl/YfQZ7VqJZ3Eo6cV39" target="_blank" rel="noopener noreferrer" class="text-xs font-500 text-on-surface-variant tracking-wide underline decoration-secondary/30 underline-offset-2 hover:decoration-secondary">モビリティリゾートもてぎ 南コース</a>
      </div>
    </header>

    {/* SVGマップ */}
    <section class="px-4 mb-6">
      <div class="relative bg-surface-container-low rounded-2xl overflow-hidden overflow-x-auto -mx-1 shadow-[0_8px_30px_rgba(0,0,0,0.12)]">
        <img src={mapSrc} alt="会場マップ" class="w-full h-auto block" />
      </div>
    </section>

    {/* 南ゲート案内 */}
    <section class="px-4 mb-8">
      <a href="https://maps.app.goo.gl/YfQZ7VqJZ3Eo6cV39" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 bg-primary text-on-primary rounded-2xl px-5 py-4 shadow-lg active:scale-98 transition-transform">
        <span class="i-ph-sign-in-duotone text-2xl shrink-0" />
        <p class="font-display font-800 text-base tracking-wide">南ゲートからご入場ください</p>
        <span class="i-ph-arrow-square-out text-lg shrink-0 opacity-70" />
      </a>
    </section>

  </main>
  <Nav />
</Layout>
