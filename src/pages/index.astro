---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/common/Nav.astro';
import Countdown from '../components/Countdown';
import NowPlaying from '../components/NowPlaying';
---
<Layout>
  <main class="min-h-screen pb-28">

    {/* コンパクトヘッダー */}
    <header class="px-6 pt-12 pb-2 max-w-lg mx-auto">
      <p class="label-upper text-on-surface-variant mb-1">2026.04.26 SUN — もてぎ南コース</p>
      <h1 class="font-display font-900 text-3xl tracking-tighter text-on-surface leading-none">
        YouTuber<br/>旧車サミット
      </h1>
    </header>

    {/* カウントダウン + NowPlaying */}
    <section class="px-5 mt-4">
      <div class="grid grid-cols-1 gap-3 max-w-lg mx-auto">
        <div class="card-elevated p-5">
          <p class="label-upper text-on-surface-variant mb-4">開催まで</p>
          <Countdown client:load />
        </div>
        <NowPlaying client:load />
      </div>
    </section>

    {/* メイン CTA: オークション & 投票 */}
    <section class="px-5 mt-6">
      <div class="grid grid-cols-1 gap-3 max-w-lg mx-auto reveal-stagger">

        {/* オークション */}
        <a href="/auction" class="block bg-on-surface text-surface rounded-2xl p-5 relative overflow-hidden card-press reveal">
          <div class="absolute right-0 top-0 h-full w-40 bg-white/5 skew-x-[-20deg] translate-x-16" />
          <div class="relative z-10 flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl flex-center bg-white/10 shrink-0">
              <span class="i-ph-gavel-duotone text-3xl" />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-[10px] tracking-widest font-700 uppercase opacity-50 mb-1">13:00 START</p>
              <h2 class="font-display font-800 text-lg tracking-tight leading-snug">チャリティー<br/>オークション</h2>
              <p class="text-xs opacity-60 mt-1.5">YouTuberの出品物にアプリで入札!</p>
            </div>
            <span class="i-ph-caret-right-bold text-xl opacity-30 shrink-0" />
          </div>
        </a>

        {/* 車両グランプリ投票 */}
        <a href="/vote" class="block bg-tertiary text-on-tertiary rounded-2xl p-5 relative overflow-hidden card-press reveal">
          <div class="absolute right-0 top-0 h-full w-40 bg-white/5 skew-x-[-20deg] translate-x-16" />
          <div class="relative z-10 flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl flex-center bg-white/10 shrink-0">
              <span class="i-ph-trophy-duotone text-3xl" />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-[10px] tracking-widest font-700 uppercase opacity-50 mb-1">〜13:30 締切</p>
              <h2 class="font-display font-800 text-lg tracking-tight leading-snug">車両グランプリ<br/>投票</h2>
              <p class="text-xs opacity-60 mt-1.5">お気に入りの一台に投票しよう!</p>
            </div>
            <span class="i-ph-caret-right-bold text-xl opacity-30 shrink-0" />
          </div>
        </a>

      </div>
    </section>

    {/* クイックナビ */}
    <section class="px-5 mt-6">
      <div class="grid grid-cols-3 gap-3 max-w-lg mx-auto reveal-stagger">
        <a href="/map" class="card-base text-center card-press reveal py-5">
          <div class="w-10 h-10 rounded-full flex-center bg-secondary-fixed mx-auto mb-2">
            <span class="i-ph-map-trifold-duotone text-lg text-on-secondary-fixed" />
          </div>
          <span class="font-display font-700 text-xs text-on-surface">会場マップ</span>
        </a>
        <a href="/schedule" class="card-base text-center card-press reveal py-5">
          <div class="w-10 h-10 rounded-full flex-center bg-tertiary-fixed mx-auto mb-2">
            <span class="i-ph-clock-countdown-duotone text-lg text-on-tertiary-fixed" />
          </div>
          <span class="font-display font-700 text-xs text-on-surface">スケジュール</span>
        </a>
        <a href="/creators" class="card-base text-center card-press reveal py-5">
          <div class="w-10 h-10 rounded-full flex-center bg-secondary-fixed mx-auto mb-2">
            <span class="i-ph-users-three-duotone text-lg text-on-secondary-fixed" />
          </div>
          <span class="font-display font-700 text-xs text-on-surface">出演者・協賛</span>
        </a>
      </div>
    </section>

    {/* 会場情報 */}
    <section class="px-5 mt-6 mb-8">
      <div class="max-w-lg mx-auto card-tonal reveal">
        <h3 class="font-display font-700 text-sm text-on-surface mb-4 tracking-tight flex items-center gap-2">
          <div class="w-7 h-7 rounded-full flex-center bg-tertiary-fixed">
            <span class="i-ph-info-duotone text-sm text-on-tertiary-fixed" />
          </div>
          会場情報
        </h3>
        <div class="space-y-3 text-sm">
          <div class="flex items-start gap-3">
            <span class="i-ph-map-pin-duotone text-base text-on-surface-variant mt-0.5 shrink-0" />
            <div>
              <p class="font-display font-600 text-on-surface">モビリティリゾートもてぎ 南コース</p>
              <p class="text-on-surface-variant text-xs mt-0.5">栃木県芳賀郡茂木町桧山120-1</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="i-ph-clock-duotone text-base text-on-surface-variant mt-0.5 shrink-0" />
            <div>
              <p class="font-display font-600 text-on-surface">9:00〜15:00</p>
              <p class="text-on-surface-variant text-xs mt-0.5">8:00 ゲートオープン（南ゲート）</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="i-ph-car-profile-duotone text-base text-on-surface-variant mt-0.5 shrink-0" />
            <div>
              <p class="font-display font-600 text-on-surface">展示車両 247台 / 全5エリア</p>
              <p class="text-on-surface-variant text-xs mt-0.5">A〜E + 茨城ゾーン</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* チケット情報（折りたたみ） */}
    <section class="px-5 mb-8">
      <details class="max-w-lg mx-auto">
        <summary class="card-tonal cursor-pointer list-none flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full flex-center bg-secondary-fixed">
              <span class="i-ph-ticket-duotone text-sm text-on-secondary-fixed" />
            </div>
            <span class="font-display font-700 text-sm text-on-surface tracking-tight">チケット情報</span>
          </div>
          <span class="i-ph-caret-down-bold text-on-surface-variant text-sm transition-transform duration-200 details-arrow" />
        </summary>
        <div class="bg-surface-container-low rounded-b-xl px-5 pb-5 -mt-3 pt-6 space-y-2 text-sm">
          <div class="flex justify-between items-center bg-surface-container-lowest rounded-xl px-4 py-3">
            <span class="text-on-surface-variant">展示車両チケット</span>
            <span class="font-display font-700 text-on-surface">¥8,000<span class="text-xs font-400 text-on-surface-variant">/台</span></span>
          </div>
          <div class="flex justify-between items-center bg-surface-container-lowest rounded-xl px-4 py-3">
            <span class="text-on-surface-variant">一般入場 (前売り)</span>
            <span class="font-display font-700 text-on-surface">¥1,500<span class="text-xs font-400 text-on-surface-variant">/人</span></span>
          </div>
          <div class="flex justify-between items-center bg-surface-container-lowest rounded-xl px-4 py-3">
            <span class="text-on-surface-variant">一般入場 (当日)</span>
            <span class="font-display font-700 text-on-surface">¥2,500<span class="text-xs font-400 text-on-surface-variant">/人</span></span>
          </div>
          <p class="text-[11px] text-on-surface-variant mt-3 leading-relaxed">
            ※ 前売りにはもてぎ入場料・駐車場代が含まれます。当日券は別途もてぎ入場料(大人¥1,900)・駐車場代(¥1,000)が必要。
          </p>
        </div>
      </details>
    </section>

  </main>

  <Nav />
</Layout>

<style>
  details[open] .details-arrow {
    transform: rotate(180deg);
  }
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
