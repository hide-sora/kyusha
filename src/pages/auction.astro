---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/common/Nav.astro';
import AuctionShowcase from '../components/Auction/AuctionShowcase';
---
<Layout title="オークション">
  <main class="min-h-screen pb-nav-safe">
    <header class="px-6 pt-12 pb-6 max-w-lg mx-auto">
      <p class="label-upper text-tertiary mb-2">お楽しみ企画</p>
      <h1 class="font-display font-800 text-4xl tracking-tight text-on-surface mb-3">
        チャリティーオークション
      </h1>
      <p class="text-sm text-on-surface-variant leading-relaxed mb-3">
        会場に来た人しか買えない！イベント当日しか買えない品の数々。スマホからその場で入札できます。出品物は順次公開していきますのでお楽しみに！
      </p>
      <div class="flex flex-wrap items-center gap-2">
        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-tertiary-container text-on-tertiary-container rounded-full text-xs font-600">
          <span class="i-ph-gavel-duotone text-sm" />
          13:00 スタート
        </div>
        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-secondary-container text-on-secondary-container rounded-full text-xs font-600">
          <span class="i-ph-ticket-duotone text-sm" />
          追加チケット不要
        </div>
      </div>
    </header>

    <!-- Showcase slider -->
    <section class="mb-6">
      <div class="px-6 max-w-lg mx-auto mb-4">
        <h2 class="font-display font-700 text-sm text-on-surface flex items-center gap-2">
          <div class="w-7 h-7 rounded-full flex-center bg-tertiary-fixed">
            <span class="i-ph-gavel-duotone text-sm text-on-tertiary-fixed" />
          </div>
          出品ラインナップ
        </h2>
      </div>
      <AuctionShowcase client:load />
    </section>
  </main>
  <Nav />
</Layout>
