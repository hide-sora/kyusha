---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/common/Nav.astro';
import AuctionPage from '../components/Auction/AuctionPage';
import RevealGate from '../components/common/RevealGate.astro';
import { reveals } from '../data/reveals';
---
<Layout title="オークション">
  <RevealGate config={reveals.auction}>
  <main class="min-h-screen pb-nav-safe">
    <header class="px-6 pt-12 pb-8 max-w-lg mx-auto">
      <p class="label-upper text-tertiary mb-2">お楽しみ企画</p>
      <h1 class="font-display font-800 text-4xl tracking-tight text-on-surface mb-3">
        チャリティーオークション
      </h1>
      <p class="text-sm text-on-surface-variant leading-relaxed mb-3">
        YouTuberの私物が出品されます！スマホからその場で入札できます。出品物は順次公開していきますのでお楽しみに！
      </p>
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-tertiary-container text-on-tertiary-container rounded-full text-xs font-600">
        <span class="i-ph-gavel-duotone text-base" />
        13:00 スタート
      </div>
    </header>

    <AuctionPage client:load />
  </main>
  </RevealGate>

  <Nav />
</Layout>
