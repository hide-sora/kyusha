---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/common/Nav.astro';
import AuctionPage from '../components/Auction/AuctionPage';
---
<Layout title="オークション">
  <main class="min-h-screen pb-20 pt-6">
    <header class="px-5 mb-6">
      <h1 class="section-title text-foreground">
        <span class="i-ph-gavel-duotone text-primary mr-2 align-middle" />
        オークション
      </h1>
      <p class="text-xs text-muted-foreground mt-1">13:00〜 チャリティーオークション</p>
    </header>

    <AuctionPage client:load />
  </main>

  <Nav />
</Layout>
