---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home', icon: 'i-ph-house-duotone' },
  { href: '/map', label: 'Map', icon: 'i-ph-map-trifold-duotone' },
  { href: '/schedule', label: 'Schedule', icon: 'i-ph-clock-countdown-duotone' },
  { href: '/auction', label: 'Auction', icon: 'i-ph-gavel-duotone' },
  { href: '/vote', label: 'Vote', icon: 'i-ph-trophy-duotone' },
  { href: '/creators', label: 'Guest', icon: 'i-ph-users-three-duotone' },
];
---
<nav class="fixed bottom-0 left-0 right-0 z-50 glass rounded-t-xl shadow-[0_-20px_40px_rgba(46,51,54,0.06)] safe-area-bottom">
  <div class="flex justify-around items-center px-4 pt-3 pb-5 max-w-lg mx-auto">
    {navItems.map(item => {
      const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
      return (
        <a
          href={item.href}
          class:list={[
            'relative flex flex-col items-center justify-center transition-all active:scale-85 duration-200',
            isActive ? 'text-zinc-900 font-700 scale-110' : 'text-zinc-400 hover:text-zinc-600',
          ]}
        >
          {isActive && <span class="nav-dot" />}
          <span class:list={[item.icon, 'text-xl transition-transform duration-200']} />
          <span class="text-[10px] tracking-widest font-500 uppercase mt-1">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<style>
  .safe-area-bottom {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
</style>
