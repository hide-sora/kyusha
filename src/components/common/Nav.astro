---
const currentPath = Astro.url.pathname;

const PB_URL = import.meta.env.PUBLIC_PB_URL || 'http://133.18.160.234:8093';
let votingOpen = false;
let auctionOpen = false;
try {
  const res = await fetch(`${PB_URL}/api/collections/event_config/records?perPage=1`);
  const data = await res.json();
  votingOpen = data.items?.[0]?.voting_open ?? false;
  auctionOpen = data.items?.[0]?.auction_open ?? false;
} catch {}

const allItems = [
  { href: '/', label: 'ホーム', icon: 'i-ph-house-duotone', show: true },
  { href: '/map', label: 'マップ', icon: 'i-ph-map-trifold-duotone', show: true },
  { href: '/schedule', label: 'スケジュール', icon: 'i-ph-clock-countdown-duotone', show: true },
  { href: '/auction', label: 'オークション', icon: 'i-ph-gavel-duotone', show: auctionOpen },
  { href: '/vote', label: '投票', icon: 'i-ph-trophy-duotone', show: votingOpen },
  { href: '/creators', label: 'ゲスト', icon: 'i-ph-users-three-duotone', show: true },
];
const navItems = allItems.filter(i => i.show);
const colsClass = `grid-cols-${navItems.length}`;
---
<nav class="fixed bottom-0 left-0 right-0 z-50 glass rounded-t-xl shadow-[0_-20px_40px_rgba(46,51,54,0.06)] safe-area-bottom">
  <div class:list={['grid items-center px-2 pt-3 pb-5 max-w-lg mx-auto', colsClass]}>
    {navItems.map(item => {
      const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
      return (
        <a
          href={item.href}
          class:list={[
            'relative flex flex-col items-center justify-center transition-all active:scale-85 duration-200',
            isActive ? 'text-zinc-900 font-700 scale-110' : 'text-zinc-400 hover:text-zinc-600',
          ]}
        >
          {isActive && <span class="nav-dot" />}
          <span class:list={[item.icon, 'text-xl transition-transform duration-200']} />
          <span class="text-[9px] tracking-wide font-500 mt-1">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<style>
  .safe-area-bottom {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
</style>
