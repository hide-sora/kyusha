---
import LockCountdown from './LockCountdown';
import type { RevealConfig } from '../../data/reveals';
import { formatRevealDate } from '../../data/reveals';

interface Props {
  config: RevealConfig;
}

const { config } = Astro.props;
const now = new Date();
const isLocked = now < config.date;
const revealDateStr = formatRevealDate(config.date);
---

{isLocked ? (
  <div class="lock-screen">

    {/* Background layers */}
    <div class="lock-bg-grid" />
    <div class="lock-bg-glow" />

    {/* Lock icon with orbit rings */}
    <div class="lock-icon-wrap">
      <div class="lock-orbit lock-orbit-a" />
      <div class="lock-orbit lock-orbit-b" />
      <div class="lock-icon-inner">
        <span class="i-ph-lock-key-duotone lock-icon-glyph" />
      </div>
    </div>

    {/* Text */}
    <div class="lock-text">
      <p class="lock-label">{config.label}</p>
      <h2 class="lock-teaser">{config.teaser}</h2>
      <p class="lock-hint">{config.hint}</p>
    </div>

    {/* Countdown */}
    <LockCountdown client:load targetDate={config.date.toISOString()} />

    {/* Unlock date */}
    <p class="lock-date">{revealDateStr} 解禁予定</p>

    {/* Bottom brand line */}
    <div class="lock-brand">
      <span class="lock-brand-line" />
      <span class="lock-brand-text">KYUSHA SUMMIT 2026</span>
      <span class="lock-brand-line" />
    </div>
  </div>
) : (
  <slot />
)}

<style>
  .lock-screen {
    min-height: 100svh;
    padding-bottom: var(--nav-h);
    background: #09090b;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    position: relative;
    overflow: hidden;
    gap: 0;
  }

  /* Subtle grid */
  .lock-bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.035;
    background-image:
      linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* Radial golden glow */
  .lock-bg-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 65% 45% at 50% 45%, rgba(251,191,36,0.07) 0%, transparent 70%);
  }

  /* Lock icon */
  .lock-icon-wrap {
    position: relative;
    width: 88px;
    height: 88px;
    margin-bottom: 2rem;
    margin-top: 1rem;
    flex-shrink: 0;
  }

  .lock-icon-inner {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: rgba(251,191,36,0.07);
    border: 1px solid rgba(251,191,36,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lock-icon-glyph {
    width: 2.5rem;
    height: 2.5rem;
    color: #fbbf24;
    filter: drop-shadow(0 0 10px rgba(251,191,36,0.5));
    animation: lockPulse 3s ease-in-out infinite;
  }

  .lock-orbit {
    position: absolute;
    border-radius: 9999px;
    pointer-events: none;
  }

  .lock-orbit-a {
    /* 140% of 88px = 123px → center offset = (123-88)/2 = 17.5px */
    width: 123px;
    height: 123px;
    top: -17.5px;
    left: -17.5px;
    border: 1px solid rgba(251,191,36,0.18);
    animation: orbit 10s linear infinite;
  }

  .lock-orbit-b {
    /* 185% of 88px = 163px → offset = (163-88)/2 = 37.5px */
    width: 163px;
    height: 163px;
    top: -37.5px;
    left: -37.5px;
    border: 1px dashed rgba(251,191,36,0.09);
    animation: orbit 18s linear infinite reverse;
  }

  /* Text block */
  .lock-text {
    text-align: center;
    max-width: 18rem;
    margin-bottom: 1.75rem;
  }

  .lock-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(251,191,36,0.55);
    margin-bottom: 0.5rem;
  }

  .lock-teaser {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: #fff;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 0.625rem;
  }

  .lock-hint {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.35);
    line-height: 1.5;
  }

  .lock-date {
    margin-top: 1.25rem;
    font-size: 11px;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.06em;
  }

  /* Brand line */
  .lock-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .lock-brand-line {
    display: block;
    width: 64px;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(251,191,36,0.18), transparent);
  }

  .lock-brand-text {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: rgba(251,191,36,0.25);
    white-space: nowrap;
  }

  @keyframes orbit {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @keyframes lockPulse {
    0%, 100% { opacity: 1; filter: drop-shadow(0 0 10px rgba(251,191,36,0.5)); }
    50%       { opacity: 0.75; filter: drop-shadow(0 0 18px rgba(251,191,36,0.7)); }
  }
</style>
